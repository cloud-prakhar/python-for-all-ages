# =============================================================
# .gitignore — Python For All Ages Course
# =============================================================
# This repo is the STUDENT-FACING version of the course.
# Files listed here are kept local only and never pushed to GitHub.
# =============================================================


# -------------------------------------------------------------
# AI / Claude Code working files
# These are used by Claude Code and should never be committed.
# -------------------------------------------------------------
CLAUDE.md
.claude/
MEMORY.md
memory/


# -------------------------------------------------------------
# Instructor-only content
# These files contain teacher notes, timed delivery plans,
# and teacher tips that are not meant for students.
# -------------------------------------------------------------
session_delivery/


# -------------------------------------------------------------
# Python build artifacts
# Generated automatically when Python runs — not source files.
# -------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/
*.pyo
*.pyd


# -------------------------------------------------------------
# Virtual environments
# Dependency sandboxes — installed locally, not committed.
# -------------------------------------------------------------
venv/
env/
.venv/
.env/
ENV/


# -------------------------------------------------------------
# IDE and editor files
# Per-developer settings — different for each machine.
# -------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo


# -------------------------------------------------------------
# OS-generated files
# Not part of the project — created by Windows/macOS file system.
# -------------------------------------------------------------
.DS_Store
Thumbs.db


# -------------------------------------------------------------
# Jupyter notebooks and logs
# -------------------------------------------------------------
.ipynb_checkpoints/
*.ipynb
*.log
